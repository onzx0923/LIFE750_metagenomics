library(ggplot2)
library(dplyr)
library(tidyr)

pavian_data <- read.delim("LIFE750pre3.tsv", sep = "\t", stringsAsFactors = FALSE)

# 1. Find the top 20 most abundant Genera
heat_data <- pavian_data %>%
  filter(taxRank == "G") %>%
  select(name, K1 = K1.cladeReads, K2 = K2.cladeReads, W1 = W1.cladeReads) %>%
  replace(is.na(.), 0) %>%
  mutate(Total = K1 + K2 + W1) %>%
  arrange(desc(Total)) %>%
  head(20)

# 3. Convert data to "Long" format and calculate relative percentages
heat_long <- heat_data %>%
  select(-Total) %>%
  pivot_longer(cols = c("K1", "K2", "W1"), names_to = "Sample", values_to = "Reads") %>%
  group_by(Sample) %>%
  mutate(Rel_Abund = (Reads / sum(Reads)) * 100)

# 4. Generate the Heatmap Plot
heatmap_plot <- ggplot(heat_long, aes(x = Sample, y = reorder(name, Rel_Abund), fill = Rel_Abund)) +
  geom_tile(color = "white", size = 1) + # Adds clean white borders between the tiles
  # magma palette: dark for low abundance, bright for high abundance
  scale_fill_viridis_c(option = "magma", name = "Relative\nAbundance (%)") +
  theme_minimal(base_size = 18) +
  labs(
    title = "Top 20 Genera Abundance Heatmap",
    x = "Dietary Sample",
    y = "Taxonomic Genus"
  ) +
  theme(
    axis.text.x = element_text(size = 20, face = "bold"),
    panel.grid = element_blank() # Removes background grid lines for a cleaner look
  )
